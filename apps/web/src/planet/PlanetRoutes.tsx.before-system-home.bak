      {/* CONNECTED BOARDS */}
      <Route path="staff/:slug" element={<StaffBoardPage />} />
      <Route path="lobby/:slug" element={<LobbyBoardPage />} />

      {/* LIVE BOARD */}
      <Route path="live/safari-demo" element={<SafariLiveBoard />} />
