      <Route path="guardian/household" element={<GuardianHouseholdBoard />} />
      <Route path="guardian/public/:guardianId" element={<GuardianPublicProfilePage />} />
      <Route path="guardian/mobility" element={<GuardianMobilityLiveBoard />} />
