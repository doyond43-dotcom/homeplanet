import { Link } from "react-router-dom";
import { useMemo, useState } from "react";
import type { CSSProperties } from "react";

const needs = [
  "Live Page",
  "Customer intake",
  "Booking / request flow",
  "Photo uploads",
  "Customer updates",
  "Live work board",
  "Payment link",
  "Google Business Profile",
  "Use my domain",
  "Not sure yet",
];

export default function HomePlanetMessagePage() {
  const [name, setName] = useState("");
  const [project, setProject] = useState("");
  const [contact, setContact] = useState("");
  const [message, setMessage] = useState("");
  const [selectedNeeds, setSelectedNeeds] = useState<string[]>([]);
  const [sent, setSent] = useState(false);

  const canSend = useMemo(() => {
    return name.trim().length > 1 && contact.trim().length > 2 && message.trim().length > 5;
  }, [name, contact, message]);

  function toggleNeed(need: string) {
    setSelectedNeeds((current) =>
      current.includes(need) ? current.filter((item) => item !== need) : [...current, need]
    );
  }

  function submitMessage() {
    if (!canSend) {
      alert("Add your name, best contact, and a quick message first.");
      return;
    }

    const payload = {
      name: name.trim(),
      project: project.trim(),
      contact: contact.trim(),
      needs: selectedNeeds,
      message: message.trim(),
      createdAt: new Date().toISOString(),
      source: "HomePlanet Message Us",
    };

    const key = "hp-homeplanet-message-us";
    const existing = JSON.parse(localStorage.getItem(key) || "[]");
    localStorage.setItem(key, JSON.stringify([payload, ...existing]));

    const subject = encodeURIComponent("HomePlanet message request");
    const body = encodeURIComponent(
      `Name: ${payload.name}\n` +
        `Business / Project: ${payload.project || "Not provided"}\n` +
        `Best contact: ${payload.contact}\n` +
        `Needs: ${payload.needs.length ? payload.needs.join(", ") : "Not selected"}\n\n` +
        `Message:\n${payload.message}\n\n` +
        `Source: ${payload.source}\n` +
        `Time: ${payload.createdAt}`
    );

    setSent(true);

    const gmailUrl = `https://mail.google.com/mail/?view=cm&fs=1&to=dannyscandys@gmail.com&su=${subject}&body=${body}`;
    const opened = window.open(gmailUrl, "_blank", "noopener,noreferrer");

    if (!opened) {
      window.location.href = gmailUrl;
    }
  }

  const page: CSSProperties = {
    minHeight: "100vh",
    background:
      "radial-gradient(circle at 15% 0%, rgba(52,211,153,0.15), transparent 30%), radial-gradient(circle at 85% 20%, rgba(20,184,166,0.10), transparent 28%), linear-gradient(180deg, #050505 0%, #08110d 54%, #050505 100%)",
    color: "#f8fafc",
    padding: "24px 18px 72px",
  };

  const wrap: CSSProperties = {
    width: "min(920px, 100%)",
    margin: "0 auto",
  };

  const back: CSSProperties = {
    color: "#a7f3d0",
    textDecoration: "none",
    fontWeight: 950,
    display: "inline-block",
    marginBottom: 44,
  };

  const eyebrow: CSSProperties = {
    color: "#34d399",
    fontSize: 13,
    fontWeight: 950,
    letterSpacing: "0.18em",
    textTransform: "uppercase",
    marginBottom: 14,
  };

  const h1: CSSProperties = {
    margin: 0,
    fontSize: "clamp(44px, 8vw, 82px)",
    lineHeight: 0.92,
    letterSpacing: "-0.075em",
    maxWidth: 820,
  };

  const sub: CSSProperties = {
    marginTop: 20,
    color: "#cbd5e1",
    lineHeight: 1.6,
    fontSize: 18,
    maxWidth: 740,
  };

  const card: CSSProperties = {
    marginTop: 34,
    borderRadius: 32,
    border: "1px solid rgba(255,255,255,0.09)",
    background: "linear-gradient(135deg, rgba(18,18,18,0.96), rgba(5,5,5,0.94))",
    boxShadow: "0 30px 90px rgba(0,0,0,0.42)",
    padding: "clamp(20px, 4vw, 34px)",
  };

  const input: CSSProperties = {
    width: "100%",
    boxSizing: "border-box",
    borderRadius: 18,
    border: "1px solid rgba(255,255,255,0.10)",
    background: "rgba(0,0,0,0.48)",
    color: "#f8fafc",
    padding: "17px 18px",
    fontSize: 16,
    outline: "none",
    marginBottom: 12,
  };

  const grid: CSSProperties = {
    display: "grid",
    gridTemplateColumns: "repeat(auto-fit, minmax(190px, 1fr))",
    gap: 10,
    margin: "14px 0 22px",
  };

  const button: CSSProperties = {
    width: "100%",
    border: 0,
    borderRadius: 999,
    background: canSend ? "#34d399" : "rgba(255,255,255,0.16)",
    color: canSend ? "#04110c" : "#94a3b8",
    padding: "16px 18px",
    fontWeight: 1000,
    fontSize: 16,
    boxShadow: canSend ? "0 0 35px rgba(52,211,153,0.28)" : "none",
    cursor: "pointer",
  };

  return (
    <main style={page}>
      <div style={wrap}>
        <Link to="/planet/live-pages/included" style={back}>
          Back to what is included
        </Link>

        <div style={eyebrow}>HOMEPLANET</div>
        <h1 style={h1}>You made it this far. Let’s figure out what you’re building.</h1>
        <p style={sub}>
          Send us a quick message. Tell us what you’re working on, what feels messy, or what you need help
          figuring out. We’ll point you in the right direction.
        </p>

        <section style={card}>
          {sent && (
            <div
              style={{
                borderRadius: 22,
                border: "1px solid rgba(52,211,153,0.30)",
                background: "rgba(52,211,153,0.10)",
                color: "#bbf7d0",
                padding: 16,
                fontWeight: 900,
                marginBottom: 18,
              }}
            >
              Message saved. Gmail should open with the message ready to send.
            </div>
          )}

          <input style={input} placeholder="Your name" value={name} onChange={(event) => setName(event.target.value)} />
          <input
            style={input}
            placeholder="Business name or project name"
            value={project}
            onChange={(event) => setProject(event.target.value)}
          />
          <input
            style={input}
            placeholder="Best contact: phone, email, or Facebook name"
            value={contact}
            onChange={(event) => setContact(event.target.value)}
          />

          <div style={{ ...eyebrow, color: "#94a3b8", marginTop: 14 }}>WHAT DO YOU NEED HELP WITH?</div>
          <div style={grid}>
            {needs.map((need) => {
              const active = selectedNeeds.includes(need);

              return (
                <button
                  key={need}
                  type="button"
                  onClick={() => toggleNeed(need)}
                  style={{
                    borderRadius: 18,
                    border: active ? "1px solid rgba(52,211,153,0.70)" : "1px solid rgba(52,211,153,0.18)",
                    background: active ? "rgba(52,211,153,0.16)" : "rgba(255,255,255,0.04)",
                    color: active ? "#bbf7d0" : "#f8fafc",
                    padding: "14px 12px",
                    fontWeight: 950,
                    textAlign: "center",
                    fontSize: 14,
                    cursor: "pointer",
                    boxShadow: active ? "0 0 24px rgba(52,211,153,0.14)" : "none",
                  }}
                >
                  {need}
                </button>
              );
            })}
          </div>

          <textarea
            style={{ ...input, minHeight: 150, resize: "vertical", lineHeight: 1.5 }}
            placeholder="Example: I have a service business and most people message me on Facebook. I need a cleaner way to collect requests, photos, updates, and payments."
            value={message}
            onChange={(event) => setMessage(event.target.value)}
          />

          <button style={button} onClick={submitMessage}>
            Send Message
          </button>
        </section>
      </div>
    </main>
  );
}

