    const name = safeText(r.payload?.name || "Customer", 40);
    const message = safeText(r.payload?.message || "", 160);
    const selected = active?.id === r.id;

    return (
      <div
        onClick={() => setActive(r)}
        className={`cursor-pointer rounded-xl border p-4 ${
          selected
            ? "border-blue-400 bg-slate-800"
            : "border-emerald-400/25 bg-slate-900/95 hover:border-blue-400"
