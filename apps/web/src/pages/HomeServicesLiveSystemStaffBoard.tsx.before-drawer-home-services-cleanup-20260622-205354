        <div className="flex items-start justify-between gap-3">
          <div className="font-bold text-lg">{vehicle}</div>
          <div className={"text-xs font-semibold " + stageColor(stage)}>
            {STAGES.find((s) => s.key === stage)?.label ?? stage}
          </div>
        </div>
        <div className="text-sm text-slate-300">{name}</div>
        <div className="text-xs text-slate-300 mt-1">{message}</div>
        <div className="mt-2 text-[11px] text-slate-400 flex items-center justify-between">
          <span>{formatTime(r.created_at)}</span>
          {r.stage_updated_by_employee_code ? (
            <span>
              Last:{" "}
              <span className="text-slate-200 font-semibold">
                {r.stage_updated_by_employee_code}
                {r.stage_updated_at ? ` @ ${formatTime(r.stage_updated_at)}` : ""}
              </span>
            </span>
          ) : null}
        </div>
      </div>
    );
  }

  return (
    <div className="h-screen bg-slate-950 text-white flex flex-col">
      <div className="border-b border-emerald-400/25 px-6 py-4 flex items-center justify-between gap-4">
        <div className="min-w-0">
          <div className="text-lg font-bold flex items-center gap-2">
            <span>Home Services Staff Board</span>
            <span className="text-[11px] text-emerald-300 font-semibold rounded-md border border-emerald-500/30 bg-emerald-500/10 px-2 py-0.5">
              safe demo
            </span>
          </div>
          <div className="text-xs text-slate-300 truncate">/planet/demo/home-services-staff</div>
        </div>

        <div className="flex items-center gap-2">
          <input
            placeholder="Customer lookup demo"
            className="w-[360px] hidden lg:block rounded-lg border border-emerald-400/30 bg-slate-900/95 px-3 py-2 text-sm outline-none"
          />
          <input
            value={employeeCode}
            onChange={(e) => setEmployeeCode(e.target.value)}
            placeholder="Employee code"
            className="w-40 rounded-lg border border-emerald-400/30 bg-slate-900/95 px-3 py-2 text-sm outline-none"
          />
          <input
