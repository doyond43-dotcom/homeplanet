    function getCanvasPoint(
    e: React.PointerEvent<HTMLCanvasElement>,
    canvas: HTMLCanvasElement,
  ) {
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    const scaleY = canvas.height / rect.height;

    return {
      x: (e.clientX - rect.left) * scaleX,
      y: (e.clientY - rect.top) * scaleY,
    };
  }

  function applyArtBrush(ctx: CanvasRenderingContext2D) {
    ctx.lineCap = "round";
    ctx.lineJoin = "round";
    ctx.lineWidth = artBrushSize;
    ctx.strokeStyle = artTool === "eraser" ? "rgba(0,0,0,1)" : artColor;
    ctx.globalCompositeOperation =
      artTool === "eraser" ? "destination-out" : "source-over";
  }

  function beginDraw(
    e: React.PointerEvent<HTMLCanvasElement>,
    target: "inline" | "studio",
  ) {
    const canvas = target === "studio" ? studioCanvasRef.current : canvasRef.current;
    const ctx = canvas?.getContext("2d");
    if (!canvas || !ctx) return;

    const point = getCanvasPoint(e, canvas);

    applyArtBrush(ctx);
    isDrawingRef.current = true;
    activeCanvasRef.current = target;

    canvas.setPointerCapture?.(e.pointerId);
    ctx.beginPath();
    ctx.moveTo(point.x, point.y);
    ctx.lineTo(point.x + 0.01, point.y + 0.01);
    ctx.stroke();
  }

  function moveDraw(
    e: React.PointerEvent<HTMLCanvasElement>,
    target: "inline" | "studio",
  ) {
    if (!isDrawingRef.current || activeCanvasRef.current !== target) return;

    const canvas = target === "studio" ? studioCanvasRef.current : canvasRef.current;
    const ctx = canvas?.getContext("2d");
    if (!canvas || !ctx) return;

    const point = getCanvasPoint(e, canvas);
    applyArtBrush(ctx);
    ctx.lineTo(point.x, point.y);
    ctx.stroke();
  }

  function endDraw(e?: React.PointerEvent<HTMLCanvasElement>) {
    const target = activeCanvasRef.current;
    const canvas =
      target === "studio"
        ? studioCanvasRef.current
        : target === "inline"
          ? canvasRef.current
          : null;

    if (canvas && e) {
      try {
        canvas.releasePointerCapture?.(e.pointerId);
      } catch {
      }
    }

    isDrawingRef.current = false;
    activeCanvasRef.current = null;
  }

  function clearCanvas(target: "inline" | "studio" = "inline") {
    const canvas = target === "studio" ? studioCanvasRef.current : canvasRef.current;
    const ctx = canvas?.getContext("2d");
    if (!canvas || !ctx) return;

    ctx.globalCompositeOperation = "source-over";
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = "#ffffff";
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    addTimeline(target === "studio" ? "Art Studio canvas cleared." : "Art pad cleared.");
  }

  function saveArtAsPng(target: "inline" | "studio" = "inline") {
    const canvas = target === "studio" ? studioCanvasRef.current : canvasRef.current;
    if (!canvas) return;

    const link = document.createElement("a");
    link.href = canvas.toDataURL("image/png");
    link.download =
      target === "studio"
