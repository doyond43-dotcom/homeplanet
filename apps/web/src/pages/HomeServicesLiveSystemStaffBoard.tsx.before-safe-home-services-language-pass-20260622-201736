function safeText(x: unknown, max = 140): string {
  const s = (typeof x === "string" ? x : JSON.stringify(x ?? "")).replace(/\s+/g, " ").trim();
  if (!s) return "";
  return s.length > max ? s.slice(0, max - 1) + " " : s;
}

function isQuickJob(payload: any) {
  const txt = `${payload?.message ?? ""} ${payload?.service ?? ""}`.toLowerCase();
  return /oil|tire|battery|brake|safety|inspection|rotate/.test(txt);
}

function stageColor(stage: string) {
  switch (stage) {
    case "diagnosing":
      return "text-blue-300";
    case "waiting_parts":
      return "text-orange-300";
    case "repairing":
      return "text-emerald-300";
    case "done":
      return "text-green-300";
    default:
      return "text-slate-300";
  }
}

function formatTime(iso: string) {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso;
  return d.toLocaleTimeString([], { hour: "numeric", minute: "2-digit" });
}

export default function HomeServicesLiveSystemStaffBoard() {
  const [rows, setRows] = useState<Row[]>(DEMO_ROWS);
  const [active, setActive] = useState<Row | null>(DEMO_ROWS[0]);
  const [employeeCode, setEmployeeCode] = useState("DEMO");
  const [employeeName, setEmployeeName] = useState("Demo Staff");

  const quickRows = useMemo(() => rows.filter((r) => isQuickJob(r.payload)), [rows]);
  const longRows = useMemo(() => rows.filter((r) => !isQuickJob(r.payload)), [rows]);

  function setJobStage(row: Row, stage: JobStage) {
    const now = new Date().toISOString();

    setRows((prev) =>
      prev
        .map((r) =>
          r.id === row.id
            ? {
                ...r,
                current_stage: stage,
                stage_updated_at: now,
                stage_updated_by_employee_code: employeeCode || "DEMO",
                handled_by_employee_code: employeeCode || "DEMO",
              }
            : r
        )
        .filter((r) => r.current_stage !== "done")
    );

    if (stage === "done") {
      setActive(null);
      return;
    }

    setActive((prev) =>
      prev?.id === row.id
        ? {
            ...prev,
            current_stage: stage,
            stage_updated_at: now,
            stage_updated_by_employee_code: employeeCode || "DEMO",
            handled_by_employee_code: employeeCode || "DEMO",
          }
        : prev
    );
  }

  function JobCard({ r }: { r: Row }) {
    const stage = (r.current_stage || "diagnosing") as string;
    const vehicle = safeText(r.payload?.vehicle || "Vehicle", 48);
    const name = safeText(r.payload?.name || "Customer", 40);
    const message = safeText(r.payload?.message || "", 160);
    const selected = active?.id === r.id;

    return (
      <div
        onClick={() => setActive(r)}
        className={`cursor-pointer rounded-xl border p-4 ${
          selected
            ? "border-blue-400 bg-slate-800"
            : "border-slate-800 bg-slate-900 hover:border-blue-400"
        }`}
      >
        <div className="flex items-start justify-between gap-3">
          <div className="font-bold text-lg">{vehicle}</div>
          <div className={"text-xs font-semibold " + stageColor(stage)}>
            {STAGES.find((s) => s.key === stage)?.label ?? stage}
          </div>
        </div>
        <div className="text-sm text-slate-300">{name}</div>
        <div className="text-xs text-slate-400 mt-1">{message}</div>
        <div className="mt-2 text-[11px] text-slate-500 flex items-center justify-between">
          <span>{formatTime(r.created_at)}</span>
          {r.stage_updated_by_employee_code ? (
            <span>
              Last:{" "}
              <span className="text-slate-200 font-semibold">
                {r.stage_updated_by_employee_code}
                {r.stage_updated_at ? ` @ ${formatTime(r.stage_updated_at)}` : ""}
              </span>
            </span>
          ) : null}
        </div>
      </div>
    );
  }

  return (
    <div className="h-screen bg-slate-950 text-white flex flex-col">
      <div className="border-b border-slate-800 px-6 py-4 flex items-center justify-between gap-4">
        <div className="min-w-0">
          <div className="text-lg font-bold flex items-center gap-2">
            <span>Employee Board</span>
            <span className="text-[11px] text-emerald-300 font-semibold rounded-md border border-emerald-500/30 bg-emerald-500/10 px-2 py-0.5">
              safe demo
            </span>
          </div>
          <div className="text-xs text-slate-400 truncate">/live/taylor-creek-demo/staff</div>
        </div>

        <div className="flex items-center gap-2">
          <input
            placeholder="Customer lookup demo"
            className="w-[360px] hidden lg:block rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm outline-none"
          />
          <input
            value={employeeCode}
            onChange={(e) => setEmployeeCode(e.target.value)}
            placeholder="Employee code"
            className="w-40 rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm outline-none"
          />
          <input
            value={employeeName}
            onChange={(e) => setEmployeeName(e.target.value)}
            placeholder="Name"
            className="w-48 hidden md:block rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm outline-none"
          />
        </div>
      </div>

      <div className="flex-1 flex overflow-hidden">
        <div className="w-full p-6 overflow-y-auto">
          <div className="mb-4 rounded-xl border border-emerald-500/20 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-100">
            Safe duplicate: sample jobs only. Stage changes are local demo actions and do not write to Supabase.
          </div>

          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <div className="text-xs text-slate-400 font-semibold mb-2">Quick jobs</div>
              <div className="space-y-3">
                {quickRows.map((r) => (
                  <JobCard key={r.id} r={r} />
                ))}
              </div>
            </div>

            <div>
              <div className="text-xs text-slate-400 font-semibold mb-2">Longer jobs</div>
              <div className="space-y-3">
                {longRows.map((r) => (
                  <JobCard key={r.id} r={r} />
                ))}
              </div>
            </div>
          </div>

          <WorkOrderDrawer
            open={!!active}
            row={active}
            employeeCode={employeeCode}
            employeeName={employeeName}
            onStageChange={(stage: JobStage) => {
              if (!active) return;
              setJobStage(active, stage);
            }}
            onOpenChange={(open) => {
              if (!open) setActive(null);
            }}
          />
        </div>
      </div>
    </div>
  );
}


